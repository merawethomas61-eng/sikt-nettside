# Kopier denne filen til .env.local og fyll inn dine egne nøkler.
# .env.local er ignorert av git - aldri commit ekte nøkler.
#
# VIKTIG: Alt med VITE_-prefiks blir bakt inn i klient-bundlen og er
# synlig for alle som besøker nettsiden. Legg ALDRI hemmelige nøkler
# bak VITE_-prefiks. Hemmeligheter settes kun som server-side env vars
# i Vercel (Project Settings -> Environment Variables).

# =====================================================
# KLIENT-SIDE (sendes til nettleseren — kun offentlige verdier!)
# =====================================================

# Supabase (anon-key er designet for å være offentlig)
VITE_SUPABASE_URL=https://din-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Stripe Payment Links (offentlige lenker — IKKE hemmelige nøkler).
# Hentes fra Stripe Dashboard -> Payment Links. Bruk test_-lenker lokalt,
# og sett LIVE-lenkene i Vercel (Production). Lar du dem stå tomme får
# kunden en feilmelding i stedet for å bli sendt til en død/test-lenke.
VITE_STRIPE_BASIC_LINK=
VITE_STRIPE_STANDARD_LINK=
VITE_STRIPE_PREMIUM_LINK=

# =====================================================
# SERVER-SIDE (kun i Vercel env vars — ALDRI commit disse!)
# =====================================================
# Disse settes i Vercel Dashboard -> Project -> Settings -> Environment Variables.
# De brukes KUN fra /api/*-endepunkter, aldri fra klient.

# OpenAI (brukes av /api/openai-chat og /api/solve-problem)
# OPENAI_API_KEY=sk-...

# Google PageSpeed (brukes av /api/pagespeed)
# PAGESPEED_API_KEY=AIza...

# SerpAPI (brukes av /api/search)
# SERP_API_KEY=...

# Stripe (brukes av /api/webhook)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service role (brukes av /api/webhook for å overstyre RLS)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (e-post: kontaktskjema /api/contact, dunning og ukerapporter)
# RESEND_API_KEY=re_...
# FROM_EMAIL=rapport@siktseo.com        # må være verifisert domene i Resend
# CONTACT_TO_EMAIL=siktseo@gmail.com     # hvor kontaktskjema-meldinger havner

# Outreach del 2 (scripts/outreach-send.mjs — sender godkjente utkast).
# Egen avsender for outreach, atskilt fra transaksjons-rapport@ for å skåne
# den domene-reputasjonen. Begge må være verifisert domene i Resend.
# Org.nr/adresse i footeren hentes fra src/shared/companyInfo.ts (ikke her).
# OUTREACH_FROM=Sikt <hei@siktseo.com>
# OUTREACH_REPLY_TO=siktseo@gmail.com    # en innboks et menneske faktisk leser
