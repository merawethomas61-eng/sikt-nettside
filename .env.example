# Kopier denne filen til .env.local og fyll inn dine egne nøkler.
# .env.local er ignorert av git - aldri commit ekte nøkler.
#
# VIKTIG: Alt med VITE_-prefiks blir bakt inn i klient-bundlen og er
# synlig for alle som besøker nettsiden. Legg ALDRI hemmelige nøkler
# bak VITE_-prefiks. Hemmeligheter settes kun som server-side env vars
# i Vercel (Project Settings -> Environment Variables).

# =====================================================
# KLIENT-SIDE (sendes til nettleseren — kun offentlige verdier!)
# =====================================================

# Supabase (anon-key er designet for å være offentlig)
VITE_SUPABASE_URL=https://din-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Stripe Payment Links (offentlige lenker — IKKE hemmelige nøkler).
# Hentes fra Stripe Dashboard -> Payment Links. Bruk test_-lenker lokalt,
# og sett LIVE-lenkene i Vercel (Production). Lar du dem stå tomme får
# kunden en feilmelding i stedet for å bli sendt til en død/test-lenke.
VITE_STRIPE_BASIC_LINK=
VITE_STRIPE_STANDARD_LINK=
VITE_STRIPE_PREMIUM_LINK=

# PostHog (samtykke-gatet sporing, se src/analytics.ts). Prosjekt-nøkkelen er
# offentlig. Uten nøkkel: ingen sporing OG ingen cookie-banner. Host er valgfri
# og faller tilbake til EU-instansen.
VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Stripe Customer Portal «no-code» login-lenke (Stripe Dashboard -> Settings ->
# Billing -> Customer portal). Brukes til oppsigelse + faktura-lenken i
# portalens Innstillinger. Tom = ærlig e-post-fallback ved oppsigelse.
VITE_STRIPE_BILLING_PORTAL_URL=

# Google OAuth client-id for «Koble til Search Console»-knappen i portalen
# (samme klient som GOOGLE_CLIENT_ID-secreten i Supabase). Tom = knappen
# viser feilmelding i stedet for å starte OAuth.
VITE_GOOGLE_CLIENT_ID=

# Sentry feillogging i nettleseren (index.tsx). Tom = ingen Sentry.
VITE_SENTRY_DSN=

# =====================================================
# SERVER-SIDE (kun i Vercel env vars — ALDRI commit disse!)
# =====================================================
# Disse settes i Vercel Dashboard -> Project -> Settings -> Environment Variables.
# De brukes KUN fra /api/*-endepunkter, aldri fra klient.

# OpenAI (brukes av /api/openai-chat og /api/solve-problem)
# OPENAI_API_KEY=sk-...

# Google PageSpeed (brukes av /api/pagespeed)
# PAGESPEED_API_KEY=AIza...

# SerpAPI (brukes av /api/search)
# SERP_API_KEY=...

# Stripe (brukes av Supabase edge-funksjonen stripe-webhook — settes som
# Supabase secrets, IKKE i Vercel). Signing-secreten kommer fra webhook-
# endepunktet i Stripe Dashboard, og navnet må være nøyaktig dette
# (supabase/functions/stripe-webhook/index.ts leser det).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...

# Supabase service role (overstyrer RLS). Brukes av /api/*-endepunktene i
# Vercel; i edge-funksjoner auto-injiseres den av Supabase.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CRON_SECRET — delt hemmelighet som beskytter cron-endepunktene. Må settes
# BÅDE i Vercel (api/cron-scan-competitors, api/wordpress-push) og som
# Supabase secret (weekly-reports, review-followup, send-review-request).
# CRON_SECRET=

# Resend (e-post: kontaktskjema /api/contact, dunning og ukerapporter)
# RESEND_API_KEY=re_...
# FROM_EMAIL=rapport@siktseo.com        # må være verifisert domene i Resend
# CONTACT_TO_EMAIL=siktseo@gmail.com     # hvor kontaktskjema-meldinger havner

# Outreach del 2 (scripts/outreach-send.mjs — sender godkjente utkast).
# Egen avsender for outreach, atskilt fra transaksjons-rapport@ for å skåne
# den domene-reputasjonen. Begge må være verifisert domene i Resend.
# Org.nr/adresse i footeren hentes fra src/shared/companyInfo.ts (ikke her).
# OUTREACH_FROM=Sikt <hei@siktseo.com>
# OUTREACH_REPLY_TO=siktseo@gmail.com    # en innboks et menneske faktisk leser

# AI-nøkler (brukes av /api/cron-scan-competitors og /api/scan-competitor:
# konkurrent-analyse, GEO-sjekker mot ChatGPT/Gemini/Perplexity)
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# PERPLEXITY_API_KEY=pplx-...

# Kryptering av lagrede tokens (WordPress i api/_lib/crypto.js + GSC i
# edge-funksjonene). SAMME verdi må settes i Vercel OG som Supabase secret —
# ellers kan ikke edge-funksjonene lese det Vercel-siden krypterte.
# ENCRYPTION_KEY=

# Sentry server-side (/api/* via api/_lib/sentry.js). Tom = ingen Sentry.
# SENTRY_DSN=

# Base-URL for lenker generert server-side (bl.a. gbp-reviews OAuth-retur).
# APP_BASE_URL=https://siktseo.com

# =====================================================
# SUPABASE EDGE FUNCTION SECRETS (Dashboard -> Edge Functions -> Secrets)
# =====================================================
# Disse leses KUN av Supabase-funksjonene — de skal ikke i Vercel.

# stripe-webhook: price-ID-er som mapper checkout -> plan. VIKTIG å sette før
# MVA-registrering/prisendring — uten dem faller webhooken tilbake på en skjør
# beløps-mapping som slutter å treffe når totalbeløpet endres.
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_STANDARD=price_...
# STRIPE_PRICE_PREMIUM=price_...

# Eiervarsler (betaling uten konto, webhook-krasj, feilet plan-bytte) og
# founder-digest i weekly-reports. Fallback: SUPPORT_EMAIL.
# FOUNDER_EMAIL=siktseo@gmail.com
# SUPPORT_EMAIL=siktseo@gmail.com

# scan-pagespeed (edge) leser GOOGLE_PAGESPEED_API_KEY eller PAGESPEED_API_KEY
# (samme Google-nøkkel som PAGESPEED_API_KEY i Vercel over).
# GOOGLE_PAGESPEED_API_KEY=AIza...

# Google OAuth for Search Console-kobling (google-oauth-callback +
# scan-search-console) og GBP (gbp-reviews).
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# FRONTEND_URL=https://siktseo.com      # retur-URL etter OAuth (default siktseo.com)
# GBP_TOKEN_SECRET=                     # signering av GBP-OAuth-state
# GOOGLE_PLACES_API_KEY=AIza...         # google-reviews (ekte rating/antall)

# resend-webhook: Svix-signatur-verifisering. Tom = signatur-sjekk HOPPES OVER
# (funksjonen godtar alt) — sett den så webhooken ikke kan forfalskes.
# RESEND_WEBHOOK_SECRET=whsec_...
