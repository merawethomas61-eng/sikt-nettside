# Kopier denne filen til .env.local og fyll inn dine egne nøkler.
# .env.local er ignorert av git - aldri commit ekte nøkler.

# Supabase (public-safe, men rotér hvis eksponert)
VITE_SUPABASE_URL=https://din-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Stripe (publishable key kun - aldri commit secret key sk_*)
STRIPE_PUBLIC_KEY=pk_test_...

# Google AI / Gemini / PageSpeed
VITE_GEMINI_API_KEY=
VITE_PAGESPEED_API_KEY=

# SerpAPI
VITE_SERP_API_KEY=
